{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stage-output-common.schema.json",
  "title": "Common Stage Output",
  "type": "object",
  "required": ["stage", "status"],
  "properties": {
    "stage": { "type": "string" },
    "status": { "type": "string" },
    "completion_status": { "type": ["object", "string"] },
    "stage_2_handoff": { "type": "object" },
    "stage_3_handoff": { "type": "object" },
    "stage_4_handoff": { "type": "object" },
    "stage_5_handoff": { "type": "object" },
    "stage_6_handoff": { "type": "object" },
    "stage_7_handoff": { "type": "object" },
    "stage_8_handoff": { "type": "object" },
    "complete_app_blueprint_markdown_path": { "type": "string" },
    "selected_stack": {
      "type": "object",
      "properties": {
        "stack_decision_id": { "type": "string" },
        "frontend": { "type": "object" },
        "backend": { "type": "object" },
        "database": { "type": "object" },
        "storage": { "type": "object" },
        "authentication": { "type": "object" },
        "hosting_and_deployment": { "type": "object" },
        "testing_stack": { "type": "object" },
        "package_manager": { "type": "string" },
        "ai_and_external_services": { "type": "array" },
        "rationale": { "type": "string" },
        "rejected_alternatives": { "type": "array" },
        "risks": { "type": "array" },
        "stage_4_implications": { "type": "array" },
        "stage_5_implications": { "type": "array" }
      },
      "additionalProperties": true
    },
    "stage_decision_brief": {
      "type": "object",
      "properties": {
        "brief_id": { "type": "string" },
        "stage": { "type": "string" },
        "brief_path": { "type": "string" },
        "recommended_direction": { "type": ["object", "string"] },
        "alternatives_considered": { "type": "array" },
        "key_decisions": { "type": "array" },
        "assumptions": { "type": "array" },
        "risks": { "type": "array" },
        "downstream_impact": { "type": ["object", "array", "string"] },
        "user_decision_required": { "type": "boolean" },
        "approval_status": {
          "type": "string",
          "enum": ["pending", "approved", "revision_requested", "blocked"]
        },
        "approved_by": { "type": "string" },
        "approved_at": { "type": "string" },
        "revision_notes": { "type": "array" }
      },
      "additionalProperties": true
    },
    "source_trace": { "type": "array" },
    "evidence_refs": { "type": "array" },
    "schema_validation": { "type": "object" },
    "reference_integrity": { "type": "object" },
    "risk_acceptance_ledger": { "type": "object" },
    "revision_loops": { "type": "array" },
    "artifact_refs": { "type": "array" }
  },
  "additionalProperties": true
}
